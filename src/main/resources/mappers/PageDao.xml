<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kcabEvent.dao.PageDao">

    <!-- 페이지 목록 조회 (섹션 수 포함) -->
    <select id="selectPageList" resultType="com.kcabEvent.dto.page.PageListDto">
        SELECT
             p.page_seq
            ,p.page_nm
            ,p.page_url
            ,p.page_title
            ,p.use_yn
            ,p.sort_seq
            ,p.rgst_date_time
            ,p.upt_date_time
            ,(SELECT COUNT(*) FROM event.page_section s WHERE s.page_seq = p.page_seq) AS section_count
        FROM event.page p
        ORDER BY p.sort_seq, p.page_seq
    </select>

    <!-- 페이지 상세 조회 (시퀀스) -->
    <select id="selectPageBySeq" resultType="com.kcabEvent.dto.page.PageDetailDto">
        SELECT
             page_seq
            ,page_nm
            ,page_url
            ,page_title
            ,page_desc
            ,use_yn
            ,sort_seq
            ,rgst_date_time
            ,upt_date_time
        FROM event.page
        WHERE page_seq = #{pageSeq}
    </select>

    <!-- 페이지 상세 조회 (URL) - 공개 페이지용 -->
    <select id="selectPageByUrl" resultType="com.kcabEvent.dto.page.PageDetailDto">
        SELECT
             page_seq
            ,page_nm
            ,page_url
            ,page_title
            ,page_desc
            ,use_yn
            ,sort_seq
            ,rgst_date_time
            ,upt_date_time
        FROM event.page
        WHERE page_url = #{pageUrl}
          AND use_yn = 'Y'
    </select>

    <!-- 섹션 목록 조회 -->
    <select id="selectSectionList" resultType="com.kcabEvent.dto.page.SectionDto">
        SELECT
             section_seq
            ,page_seq
            ,section_type
            ,section_data
            ,sort_seq
            ,use_yn
        FROM event.page_section
        WHERE page_seq = #{pageSeq}
        ORDER BY sort_seq, section_seq
    </select>

    <!-- 페이지 등록 -->
    <insert id="insertPage" parameterType="com.kcabEvent.domain.Page" useGeneratedKeys="true" keyProperty="pageSeq">
        INSERT INTO event.page (
             page_nm
            ,page_url
            ,page_title
            ,page_desc
            ,use_yn
            ,sort_seq
            ,rgst_user_seq
            ,upt_user_seq
        ) VALUES (
             #{pageNm}
            ,#{pageUrl}
            ,#{pageTitle}
            ,#{pageDesc}
            ,#{useYn}
            ,#{sortSeq}
            ,#{rgstUserSeq}
            ,#{uptUserSeq}
        )
    </insert>

    <!-- 페이지 수정 -->
    <update id="updatePage" parameterType="com.kcabEvent.domain.Page">
        UPDATE event.page
        SET  page_nm       = #{pageNm}
            ,page_url      = #{pageUrl}
            ,page_title    = #{pageTitle}
            ,page_desc     = #{pageDesc}
            ,use_yn        = #{useYn}
            ,sort_seq      = #{sortSeq}
            ,upt_user_seq  = #{uptUserSeq}
            ,upt_date_time = CURRENT_TIMESTAMP
        WHERE page_seq = #{pageSeq}
    </update>

    <!-- 페이지 삭제 -->
    <delete id="deletePage">
        DELETE FROM event.page WHERE page_seq = #{pageSeq}
    </delete>

    <!-- 섹션 등록 -->
    <insert id="insertSection" parameterType="com.kcabEvent.domain.PageSection" useGeneratedKeys="true" keyProperty="sectionSeq">
        INSERT INTO event.page_section (
             page_seq
            ,section_type
            ,section_data
            ,sort_seq
            ,use_yn
            ,rgst_user_seq
            ,upt_user_seq
        ) VALUES (
             #{pageSeq}
            ,#{sectionType}
            ,#{sectionData}::jsonb
            ,#{sortSeq}
            ,#{useYn}
            ,#{rgstUserSeq}
            ,#{uptUserSeq}
        )
    </insert>

    <!-- 섹션 수정 -->
    <update id="updateSection" parameterType="com.kcabEvent.domain.PageSection">
        UPDATE event.page_section
        SET  section_type   = #{sectionType}
            ,section_data   = #{sectionData}::jsonb
            ,sort_seq       = #{sortSeq}
            ,use_yn         = #{useYn}
            ,upt_user_seq   = #{uptUserSeq}
            ,upt_date_time  = CURRENT_TIMESTAMP
        WHERE section_seq = #{sectionSeq}
    </update>

    <!-- 섹션 삭제 (단건) -->
    <delete id="deleteSection">
        DELETE FROM event.page_section WHERE section_seq = #{sectionSeq}
    </delete>

    <!-- 섹션 삭제 (페이지 전체) -->
    <delete id="deleteSectionsByPageSeq">
        DELETE FROM event.page_section WHERE page_seq = #{pageSeq}
    </delete>

</mapper>
